---
interface Props {
	url: string;
	height?: number;
}
const { url, height = 166 } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const embedSrc = `https://w.soundcloud.com/player/?url=${encodedUrl}&color=%23D74000&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false`;
---

<div class="soundcloud-embed">
	<iframe
		width="100%"
		height={height}
		src={embedSrc}
		frameborder="0"
		allow="autoplay"
		title="SoundCloud track"
		loading="lazy"
	></iframe>
</div>

<style>
	.soundcloud-embed {
		margin: 2.4rem 0;
		border-radius: var(--border-radius-blocks);
		overflow: hidden;
	}
</style>
