---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Connor. All rights reserved.</p>
</footer>

<style>
	footer {
		padding: 3.2rem 2rem;
		border-top: 1px solid var(--border);
		color: var(--text-muted);
		font-size: 1.3rem;
		text-align: center;
		transition: border-color 0.3s;
	}

	footer p {
		margin: 0;
	}
</style>
