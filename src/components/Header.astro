---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="header-actions">
			<div class="social-links">
				<a href="https://www.strava.com" target="_blank" rel="noopener">
					<span class="sr-only">Strava</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20" fill="currentColor">
						<path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/>
					</svg>
				</a>
				<a href="https://soundcloud.com" target="_blank" rel="noopener">
					<span class="sr-only">SoundCloud</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20" fill="currentColor">
						<path d="M1.175 12.225C.528 12.225 0 12.75 0 13.379v.899c0 .63.528 1.154 1.175 1.154.648 0 1.175-.522 1.175-1.154v-.9c0-.63-.527-1.153-1.175-1.153zm2.509-.176c-.723 0-1.31.588-1.31 1.31v1.964c0 .723.587 1.31 1.31 1.31.722 0 1.31-.587 1.31-1.31v-1.964c0-.722-.588-1.31-1.31-1.31zm2.54-.76c-.873 0-1.58.707-1.58 1.58v2.161c0 .873.707 1.58 1.58 1.58.874 0 1.58-.707 1.58-1.58v-2.161c0-.873-.706-1.58-1.58-1.58zm2.406.21c-.9 0-1.629.73-1.629 1.629v2.27c0 .9.729 1.628 1.629 1.628.9 0 1.629-.728 1.629-1.628v-2.27c0-.9-.729-1.629-1.629-1.629zm10.165-.636c-.361-3.574-3.362-6.353-7.024-6.353-1.74 0-3.328.636-4.554 1.681v8.049c0 2.07 1.68 3.75 3.75 3.75h7.079c1.927 0 3.492-1.565 3.492-3.492 0-1.81-1.383-3.296-3.152-3.46-.09-.047-.418-.175-.591-.175z"/>
					</svg>
				</a>
				<a href="https://github.com" target="_blank" rel="noopener">
					<span class="sr-only">GitHub</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20" fill="currentColor">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
				</a>
				<a href="https://linkedin.com" target="_blank" rel="noopener">
					<span class="sr-only">LinkedIn</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20" fill="currentColor">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				</a>
			</div>
			<button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="5"/>
					<line x1="12" y1="1" x2="12" y2="3"/>
					<line x1="12" y1="21" x2="12" y2="23"/>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
					<line x1="1" y1="12" x2="3" y2="12"/>
					<line x1="21" y1="12" x2="23" y2="12"/>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
				</svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
				</svg>
			</button>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
		transition: background-color 0.3s, border-color 0.3s;
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 2rem;
		height: 64px;
	}

	.site-title {
		font-size: var(--body-M-font-size);
		font-weight: var(--font-weight-titles);
		color: var(--color-text);
		text-decoration: none;
		white-space: nowrap;
		opacity: 1;
		flex-shrink: 0;
	}

	.site-title:hover {
		color: var(--accent-color);
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		flex: 1;
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.social-links a {
		display: flex;
		align-items: center;
		color: var(--color-secondary-foreground);
		padding: 6px;
		border-radius: var(--border-radius-navigation);
		transition: color 0.3s, background-color 0.3s;
		opacity: 1;
	}

	.social-links a:hover {
		color: var(--color-text);
		background-color: var(--color-cur-nav-page);
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		background: none;
		border: 1px solid var(--color-border);
		border-radius: var(--border-radius-navigation);
		color: var(--color-text);
		cursor: pointer;
		transition: background-color 0.3s, border-color 0.3s;
		flex-shrink: 0;
	}

	.theme-toggle:hover {
		background-color: var(--color-cur-nav-page);
		border-color: var(--color-border--hover);
	}

	/* Dark default — show moon */
	.icon-moon { display: block; }
	.icon-sun  { display: none; }

	/* Light override — show sun */
	:global([data-theme="light"]) .icon-moon { display: none; }
	:global([data-theme="light"]) .icon-sun  { display: block; }

	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}

		.social-links {
			display: none;
		}
	}

	@media (max-width: 540px) {
		.internal-links {
			display: none;
		}
	}
</style>

<script>
	const toggle = document.getElementById('theme-toggle');
	toggle?.addEventListener('click', () => {
		const isLight = document.documentElement.getAttribute('data-theme') === 'light';
		if (isLight) {
			document.documentElement.removeAttribute('data-theme');
			localStorage.setItem('theme', 'dark');
		} else {
			document.documentElement.setAttribute('data-theme', 'light');
			localStorage.setItem('theme', 'light');
		}
	});
</script>
