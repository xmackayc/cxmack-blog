</header>

<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
		transition: background-color 0.3s, border-color 0.3s;
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 2rem;
		height: 128px;
	}

	.site-title {
		display: inline-flex;
		align-items: center;
		gap: 1.6rem;
		font-family: var(--font-display);
		font-size: 3.6rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
		opacity: 1;
		flex-shrink: 0;
	}

	.brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 60px;
		height: 60px;
		border-radius: calc(var(--radius) * 2);
		background: var(--surface-1);
		border: 1px solid var(--border);
		color: var(--text-muted);
		flex-shrink: 0;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex: 1;
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-shrink: 0;
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.social-links a {
		display: flex;
		align-items: center;
		color: var(--text-muted);
		padding: 12px;
		border-radius: calc(var(--radius) * 2);
		transition: color 0.3s, background-color 0.3s;
		opacity: 1;
	}

	.social-links a:hover {
		color: var(--text);
		background-color: var(--surface-1);
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 72px;
		height: 72px;
		background: none;
		border: 1px solid var(--border);
		border-radius: calc(var(--radius) * 2);
		color: var(--text);
		cursor: pointer;
		transition: background-color 0.3s, border-color 0.3s;
		flex-shrink: 0;
	}

	.theme-toggle:hover {
		background-color: var(--surface-1);
		border-color: var(--border-strong);
	}

	/* Dark default — show moon */
	.icon-moon { display: block; }
	.icon-sun  { display: none; }

	/* Light override — show sun */
	:global([data-theme="light"]) .icon-moon { display: none; }
	:global([data-theme="light"]) .icon-sun  { display: block; }

	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}

		.social-links {
			display: none;
		}
	}

	@media (max-width: 540px) {
		.internal-links {
			display: none;
		}
	}
</style>

<script>
	const toggle = document.getElementById('theme-toggle');
	toggle?.addEventListener('click', () => {
		const isLight = document.documentElement.getAttribute('data-theme') === 'light';
		if (isLight) {
			document.documentElement.removeAttribute('data-theme');
			localStorage.setItem('theme', 'dark');
		} else {
			document.documentElement.setAttribute('data-theme', 'light');
			localStorage.setItem('theme', 'light');
		}
	});
</script>
