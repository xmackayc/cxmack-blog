---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import HeadshotImage from '../assets/headshot.jpeg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="identity-block">
				<Image src={HeadshotImage} alt="Connor" width={96} height={96} class="headshot" />
				<div class="identity-text">
					<h1>Hey, I'm Connor.</h1>
					<p>Systems Engineer. A running log of what I'm into right now.</p>
				</div>
			</div>

			<section>
				<div class="section-header">
					<h2>Recent posts</h2>
					<a href="/blog">All posts &rarr;</a>
				</div>
				<ul class="board-grid">
					{posts.map((post) => (
						<li class="board-card">
							<a class="board-card__img-link" href={`/blog/${post.id}/`}>
								{post.data.heroImage
									? <Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={720}
											height={540}
											class="board-card__img"
										/>
									: <div class="board-card__img-placeholder" />
								}
								<span class="board-card__date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
							<div class="board-card__body">
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="board-card__tags">
										{post.data.tags.map((tag) => (
											<span class="post-tag">{tag}</span>
										))}
									</div>
								)}
								<h4 class="board-card__title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h4>
								<p class="board-card__excerpt">{post.data.description}</p>
							</div>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.board-card__img-placeholder {
		width: 100%;
		height: 100%;
		background-color: var(--color-bg-block);
	}
</style>
